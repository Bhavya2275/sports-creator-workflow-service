# Copy this file to .env and fill in your values

# ── App ──────────────────────────────────────────
APP_NAME=Creator Workflow Service
DEBUG=false
LOG_LEVEL=INFO

# ── Database ─────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://creator:creator_pass@localhost:5432/creator_workflow

# ── AI ───────────────────────────────────────────
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-5.4-mini

# ── Qualification ────────────────────────────────
QUALIFICATION_SCORE_THRESHOLD=60.0
